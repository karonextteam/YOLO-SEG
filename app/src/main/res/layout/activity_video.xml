<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/iv_video_frame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:background="@color/bg_card"
        android:contentDescription="Video frame"/>

    <ProgressBar
        android:id="@+id/progress_video"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="?android:attr/progressBarStyleHorizontal"
        android:visibility="gone"
        android:progressTint="@color/accent_green"
        android:layout_marginTop="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/tv_frame_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Frame: -/-"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_video_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hazır"
            android:gravity="end"
            android:textColor="@color/accent_green"
            android:textSize="12sp"/>
    </LinearLayout>

    <SeekBar
        android:id="@+id/seek_video_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progressTint="@color/accent_green"
        android:thumbTint="@color/accent_green"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btn_pick_video"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Video Seç"
            android:textColor="@color/bg_dark"
            android:backgroundTint="@color/accent_green"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn_save_video_frame"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Frame Kaydet"
            android:enabled="false"
            android:textColor="@color/bg_dark"
            android:backgroundTint="@color/accent_teal"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>
