<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/accent_green"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOLO Segmentation • Edge AI"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- ── Model selection ─────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinner_model"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner"
            android:popupBackground="@color/bg_card"
            android:layout_marginBottom="16dp"/>

        <!-- ── GPU toggle ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vulkan GPU"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>

            <Switch
                android:id="@+id/switch_vulkan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/accent_green"
                android:trackTint="@color/track_tint"/>
        </LinearLayout>

        <!-- ── Confidence threshold ───────────────────────── -->
        <TextView
            android:id="@+id/tv_conf_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conf: 0.25"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seek_conf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="@color/accent_green"
            android:thumbTint="@color/accent_green"
            android:layout_marginBottom="16dp"/>

        <!-- ── NMS threshold ──────────────────────────────── -->
        <TextView
            android:id="@+id/tv_nms_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NMS: 0.45"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seek_nms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="@color/accent_green"
            android:thumbTint="@color/accent_green"
            android:layout_marginBottom="16dp"/>

        <!-- ── Mask alpha ──────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_alpha_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alpha: 0.50"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seek_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="@color/accent_green"
            android:thumbTint="@color/accent_green"
            android:layout_marginBottom="24dp"/>

        <!-- ── Mode selection ─────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kaynak"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp"/>

        <RadioGroup
            android:id="@+id/radio_group_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <RadioButton
                android:id="@+id/rb_image"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Görsel"
                android:checked="true"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_green"
                android:gravity="center_vertical"/>

            <RadioButton
                android:id="@+id/rb_video"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Video"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_green"
                android:gravity="center_vertical"/>

            <RadioButton
                android:id="@+id/rb_camera"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Kamera"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_green"
                android:gravity="center_vertical"/>
        </RadioGroup>

        <!-- ── Go button ──────────────────────────────────── -->
        <Button
            android:id="@+id/btn_go"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="BAŞLAT"
            android:textColor="@color/bg_dark"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="@color/accent_green"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>
